  <diagram name="Sequence Diagram" id="XRHTEFdg30vu3tCoWi3h">
    <mxGraphModel dx="1370" dy="939" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="vCbULJYbUddzt6d0eydb-0" />
        <mxCell id="vCbULJYbUddzt6d0eydb-1" parent="vCbULJYbUddzt6d0eydb-0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle Self-Healing System - Sequence Diagram\n\nactor \&quot;System Admin\&quot; as Admin\nparticipant \&quot;Prometheus\&quot; as Prom\nparticipant \&quot;Monitoring Service\&quot; as Monitor\nparticipant \&quot;Task API\&quot; as API\nparticipant \&quot;Rule Engine\&quot; as Rules\nparticipant \&quot;Remediation Engine\&quot; as Remed\nparticipant \&quot;Diagnostic Service\&quot; as Diag\nparticipant \&quot;Learning Service\&quot; as Learn\nparticipant \&quot;Kubernetes API\&quot; as K8s\nparticipant \&quot;Notification Service\&quot; as Notify\n\n== Monitoring ==\n\nMonitor -&gt; Prom : Collect metrics\nactivate Monitor\nProm --&gt; Monitor : Metric values\n\nMonitor -&gt; API : Store metrics\nactivate API\nAPI --&gt; Monitor : Stored\ndeactivate API\n\nMonitor -&gt; Rules : Evaluate rules\nactivate Rules\nRules --&gt; Monitor : Failure event\ndeactivate Rules\n\n== Recovery ==\n\nMonitor -&gt; Remed : Trigger recovery\nactivate Remed\n\nRemed -&gt; API : Store failure event\nactivate API\nAPI --&gt; Remed : Saved\ndeactivate API\n\nRemed -&gt; Diag : Diagnose failure\nactivate Diag\nDiag -&gt; Prom : Fetch current metrics\nProm --&gt; Diag : Metrics\nDiag --&gt; Remed : Diagnosis result\ndeactivate Diag\n\nRemed -&gt; Learn : Select strategy\nactivate Learn\nLearn --&gt; Remed : Recommended strategy\ndeactivate Learn\n\nloop Recovery steps\n    Remed -&gt; K8s : Execute recovery action\n    activate K8s\n    K8s --&gt; Remed : Action result\n    deactivate K8s\n\n    Remed -&gt; API : Update recovery status\n    activate API\n    API --&gt; Remed : Updated\n    deactivate API\nend\n\nRemed -&gt; Notify : Send notification\nactivate Notify\nNotify --&gt; Admin : Alert message\ndeactivate Notify\n\ndeactivate Remed\ndeactivate Monitor\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="zuUWt1xrokjTNzg8qlEW-0">
          <mxCell parent="vCbULJYbUddzt6d0eydb-1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="915" width="1254" x="210" y="280" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="USE Case Diagram" id="bK0BsJEalD1F1U_FXoFY">
    <mxGraphModel dx="1566" dy="2173" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="VMxZ2fkhidbx1vGB3dwL-0" />
        <mxCell id="VMxZ2fkhidbx1vGB3dwL-1" parent="VMxZ2fkhidbx1vGB3dwL-0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nleft to right direction\ntitle Use Case Diagram - Self-Healing System\n\nactor \&quot;System Admin\&quot; as Admin\nactor \&quot;Prometheus\&quot; as Prom\nactor \&quot;Kubernetes API\&quot; as K8s\n\nrectangle \&quot;Self-Healing System\&quot; {\n\n  usecase \&quot;Collect Metrics\&quot; as UC1\n  usecase \&quot;Store Metrics\&quot; as UC2\n  usecase \&quot;Detect Failure\&quot; as UC3\n  usecase \&quot;Diagnose Root Cause\&quot; as UC4\n  usecase \&quot;Select Recovery Strategy\&quot; as UC5\n  usecase \&quot;Execute Recovery Action\&quot; as UC6\n  usecase \&quot;Restart Pod\&quot; as UC7\n  usecase \&quot;Scale Deployment\&quot; as UC8\n  usecase \&quot;Store Failure Event\&quot; as UC9\n  usecase \&quot;Send Alert Notification\&quot; as UC10\n  usecase \&quot;View Dashboard\&quot; as UC11\n  usecase \&quot;Trigger Stress Test\&quot; as UC12\n}\n\nProm -- UC1\nK8s -- UC7\nK8s -- UC8\n\nAdmin -- UC10\nAdmin -- UC11\nAdmin -- UC12\n\nUC1 .&gt; UC2 : &lt;&lt;include&gt;&gt;\nUC2 .&gt; UC3 : &lt;&lt;include&gt;&gt;\nUC3 .&gt; UC4 : &lt;&lt;include&gt;&gt;\nUC4 .&gt; UC5 : &lt;&lt;include&gt;&gt;\nUC5 .&gt; UC6 : &lt;&lt;include&gt;&gt;\n\nUC6 .&gt; UC7 : &lt;&lt;extend&gt;&gt;\nUC6 .&gt; UC8 : &lt;&lt;extend&gt;&gt;\n\nUC6 .&gt; UC9 : &lt;&lt;include&gt;&gt;\nUC6 .&gt; UC10 : &lt;&lt;include&gt;&gt;\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="u3OTkACgM1WuUWjRRFq6-1">
          <mxCell parent="VMxZ2fkhidbx1vGB3dwL-1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="994" width="438" x="241" y="-8" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
