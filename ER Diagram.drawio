        </mxCell>
        <mxCell id="lwDhFy6XJbLUevfUC_to-22" parent="lwDhFy6XJbLUevfUC_to-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;spacing=0;horizontal=1;textShadow=0;autosizeText=1;imageAspect=1;resizeWidth=0;autosize=0;fontSize=16;" value="• Kubernetes cluster running multiple containerized services&lt;br&gt;• TaskApi and Analyzer deployed as independent pods&lt;br&gt;• Prometheus scraping metrics every 5 seconds&lt;br&gt;• PostgreSQL storing failure and recovery records&lt;br&gt;• Grafana visualizing metric trends&lt;br&gt;• React dashboard accessible through browser&lt;br&gt;• Local Docker environment used during development&lt;br&gt;• Cluster state changes dynamically during pod restarts" vertex="1">
          <mxGeometry height="189" width="398" x="11" y="409" as="geometry" />
        </mxCell>
        <mxCell id="lwDhFy6XJbLUevfUC_to-23" parent="lwDhFy6XJbLUevfUC_to-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=12;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;Environment Characteristics&lt;/font&gt;" vertex="1">
