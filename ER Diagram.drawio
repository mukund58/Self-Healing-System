        <mxCell id="rmADn-B9cvnFvxd_TX9Z-21" parent="rmADn-B9cvnFvxd_TX9Z-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;spacing=0;horizontal=1;textShadow=0;autosizeText=1;imageAspect=1;resizeWidth=0;autosize=0;fontSize=15;" value="• TaskApi acts as the protected application service&lt;br&gt;• Analyzer performs anomaly detection and remediation logic&lt;br&gt;• FailureEvent stores detected anomaly details&lt;br&gt;• RecoveryAction stores executed healing steps&lt;br&gt;• MetricRecord stores runtime metric history&lt;br&gt;• Detection rules evaluate CPU, memory, and error rate behavior&lt;br&gt;• Recovery strategies decide restart and scaling sequence" vertex="1">
          <mxGeometry height="189" width="398" x="11" y="409" as="geometry" />
        </mxCell>
