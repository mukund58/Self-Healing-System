        <mxCell id="3t06PsIuA9gt6FggBZNt-56" parent="742ZRR7KinfPXggPbSlC-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;spacing=0;horizontal=1;textShadow=0;autosizeText=1;imageAspect=1;resizeWidth=0;autosize=0;fontSize=15;" value="&lt;ol&gt;&lt;li&gt;&lt;font&gt;&lt;font&gt;Monitoring CPU, memory, error rate every 5 seconds&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;&lt;font&gt;Detecting CPU spikes using sliding window rules&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;&lt;font&gt;Executing automatic pod restart&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;&lt;font&gt;Scaling deployment during overload&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;&lt;font&gt;Recording recovery success history&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;&lt;font&gt;Running stress endpoints for testing&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;&lt;font&gt;Monitoring dashboard in real time&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;" vertex="1">
