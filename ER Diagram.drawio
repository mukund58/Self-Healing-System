        <mxCell id="dvIYzwfbgYlH83zcDWOg-21" parent="dvIYzwfbgYlH83zcDWOg-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;spacing=0;horizontal=1;textShadow=0;autosizeText=1;imageAspect=1;resizeWidth=0;autosize=0;fontSize=14;" value="• Prometheus continuously sends metric data to the Analyzer service&lt;br&gt;• Analyzer queries metric trends and evaluates anomaly rules&lt;br&gt;• Failure events are recorded when thresholds are exceeded&lt;br&gt;• Recovery actions are triggered automatically through Kubernetes API&lt;br&gt;• Dashboard reflects live interaction between monitoring and healing services&lt;br&gt;• Learning module updates future remediation based on previous outcomes" vertex="1">
          <mxGeometry height="189" width="398" x="11" y="409" as="geometry" />
        </mxCell>
        <mxCell id="dvIYzwfbgYlH83zcDWOg-22" parent="dvIYzwfbgYlH83zcDWOg-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=12;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;Environment Characteristics&lt;/font&gt;" vertex="1">
