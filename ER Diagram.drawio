        </mxCell>
        <mxCell id="xKBuqy8DKaJkAhcU9lFn-1" parent="lwDhFy6XJbLUevfUC_to-1" style="verticalLabelPosition=bottom;verticalAlign=top;html=1;shape=mxgraph.basic.corner_round_rect;dx=6;whiteSpace=wrap;" value="" vertex="1">
          <mxGeometry height="130" width="415" y="810" as="geometry" />
        </mxCell>
        <mxCell id="xKBuqy8DKaJkAhcU9lFn-2" parent="lwDhFy6XJbLUevfUC_to-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=12;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;Special Notes / Design Insight&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="395" x="2" y="780" as="geometry" />
        </mxCell>
        <mxCell id="xKBuqy8DKaJkAhcU9lFn-3" parent="lwDhFy6XJbLUevfUC_to-1" style="shape=waypoint;sketch=0;fillStyle=solid;size=6;pointerEvents=1;points=[];fillColor=none;resizable=0;rotatable=0;perimeter=centerPerimeter;snapToPoint=1;" value="" vertex="1">
